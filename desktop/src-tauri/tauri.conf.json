{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "Odoo Rust MCP",
  "version": "0.5.1",
  "identifier": "com.odoo-rust-mcp.desktop",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://127.0.0.1:3008",
    "beforeDevCommand": "",
    "beforeBuildCommand": "powershell -ExecutionPolicy Bypass -File scripts/prebuild.ps1"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Odoo Rust MCP",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "url": "http://127.0.0.1:3008"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/rust-mcp"
    ],
    "resources": [
      "static/dist/**/*",
      "docs/book/**/*"
    ],
    "windows": {
      "wix": null,
      "nsis": {
        "installMode": "currentUser",
        "compression": "lzma",
        "installerHooks": "nsis-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUwQ0QyNEU4RjM1QzQ5NjUKUldSbFNWeno2Q1RONFBDSWdKaW4yVW5pa1pvTUg1Z3BCdVFnNkZuSkxLeTJwWmZDTXNSRnh0WGoK",
      "endpoints": [
        "https://github.com/milzamsz/odoo-rust-mcp/releases/latest/download/latest.json"
      ]
    }
  }
}
